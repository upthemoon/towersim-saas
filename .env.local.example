# --- Supabase ---
# 新規プロジェクト (https://supabase.com/dashboard) を作成し、
# Settings → API から下記2つをコピー
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# Service Role (Webhook 用・サーバ側のみで使用・絶対に NEXT_PUBLIC_ にしない)
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>


# --- Stripe ---
# Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Stripe Dashboard → Developers → Webhooks → endpoint 作成後の Signing Secret
STRIPE_WEBHOOK_SECRET=whsec_xxx

# 商品設定後 (Products → 月額/年額作成) で得られる price ID
STRIPE_PRICE_MONTHLY=price_xxx
STRIPE_PRICE_YEARLY=price_xxx


# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Analytics (Google Analytics 4 / 広告コンバージョン計測) ---
# GA4 プロパティ作成後 (https://analytics.google.com) → 管理 → データストリーム → 測定 ID
# 形式: G-XXXXXXXXXX。未設定なら GA は読み込まれず、sign_up は console.warn のみでスキップ。
# 注: NEXT_PUBLIC_ はビルド時に静的置換されるため、Vercel で値を変更したら再デプロイ必須。
NEXT_PUBLIC_GA_ID=
